---
import { SITE_TITLE } from '../consts';
import { profile } from '../data/profile';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';

const { mastodon, twitter } = profile.socialLinks;
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/notes">笔记</HeaderLink>
			<HeaderLink href="/#stack">技术</HeaderLink>
			<HeaderLink href="/#projects">个人项目</HeaderLink>
		</div>
		<div class="social-links">
			<ThemeToggle />
			{
				mastodon ? (
					<a href={mastodon} target="_blank" rel="noopener noreferrer">
						<span class="sr-only">Mastodon</span>
						<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
							<path
								fill="currentColor"
								d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
							/>
						</svg>
					</a>
				) : null
			}
			{
				twitter ? (
					<a href={twitter} target="_blank" rel="noopener noreferrer">
						<span class="sr-only">Twitter / X</span>
						<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
							<path
								fill="currentColor"
								d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
							/>
						</svg>
					</a>
				) : null
			}
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		margin: 0;
		padding: 0.75rem 1rem;
		background: var(--header-bg);
		border-bottom: 1px solid var(--line);
		backdrop-filter: blur(18px);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		letter-spacing: -0.02em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: var(--content-width);
		max-width: 100%;
		margin: 0 auto;
		gap: 1rem;
	}
	nav a {
		color: var(--muted);
		text-decoration: none;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.25rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: var(--control-bg);
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
	}
	nav a.active {
		text-decoration: none;
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links {
		align-items: center;
		gap: 0.35rem;
	}
	.social-links a {
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 50%;
		color: var(--muted);
		background: var(--control-bg);
		border: 1px solid var(--line);
	}
	.social-links a:hover {
		color: var(--accent-strong);
		transform: translateY(-1px);
	}
	.social-links svg {
		width: 1.05rem;
		height: 1.05rem;
	}
	@media (max-width: 720px) {
		header {
			padding: 0.65rem 0.75rem;
		}
		nav {
			align-items: flex-start;
			flex-direction: column;
		}
		.internal-links {
			width: 100%;
			justify-content: space-between;
		}
		.social-links {
			display: none;
		}
	}
</style>
