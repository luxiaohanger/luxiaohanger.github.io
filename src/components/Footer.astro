---
const today = new Date();
import { profile } from '../data/profile';

const owner = profile.displayName.trim() || '个人主页';
---

<footer>
	&copy; {today.getFullYear()} {owner}
</footer>
<style>
	footer {
		width: var(--content-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 2.5rem 0 4rem;
		border-top: 1px solid var(--line);
		color: var(--muted);
		text-align: center;
		font-size: 0.95rem;
	}
</style>
