---
import BasePage from '../layouts/BasePage.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<BasePage title={`关于 — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<section class="mx-auto max-w-3xl rounded-[2rem] border border-white/10 bg-zinc-900/50 p-8 shadow-2xl shadow-black/20 backdrop-blur-xl md:p-12">
		<p class="mb-4 text-xs font-medium uppercase tracking-[0.28em] text-zinc-500">About</p>
		<h1 class="text-4xl font-semibold tracking-[-0.05em] text-white md:text-5xl">关于本站</h1>
	</section>
</BasePage>
